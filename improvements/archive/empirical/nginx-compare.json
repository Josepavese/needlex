      },
      {
        "path": "/div[1]/div[2]/div[1]/table[1]/tbody[1]/tr[1]/td[2]",
        "tag": "td",
        "kind": "table_cell",
        "text": "NGINX JavaScript (njs) extends nginx functionality with an ECMAScript-compatible interpreter for HTTP and Stream modules. Docs • Code",
        "depth": 7
      },
      {
        "path": "/div[1]/div[2]/div[1]/table[2]/tbody[1]/tr[1]/td[2]",
        "tag": "td",
        "kind": "table_cell",
        "text": "NGINX Ingress Controller connects Kubernetes apps and services with rock solid request handling, auth, self-service CRDs, and easy debugging. Not to be confused with ingress-nginx, the separate Kubernetes community project. Docs • Code",
        "depth": 7
      },
      {
        "path": "/div[1]/div[2]/div[1]/table[3]/tbody[1]/tr[1]/td[2]",
        "tag": "td",
        "kind": "table_cell",
        "text": "NGINX Gateway Fabric provides L4 and L7 routing capabilities in Kubernetes, implementing the Gateway API using NGINX as the data plane. Docs • Code",
        "depth": 7
      }
    ],
