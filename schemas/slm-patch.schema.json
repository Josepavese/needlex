{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://josepavese.github.io/needlex/schemas/slm-patch.schema.json",
  "title": "NeedleXSLMPatch",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task",
    "output_json",
    "confidence"
  ],
  "properties": {
    "task": {
      "type": "string",
      "enum": [
        "resolve_ambiguity",
        "interpret_embedded_state",
        "diagnose_drift",
        "repair_evidence_graph",
        "guard_compression"
      ]
    },
    "output_json": {
      "type": "string",
      "minLength": 2
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "model": {
      "type": "string"
    },
    "finish_reason": {
      "type": "string"
    }
  }
}
