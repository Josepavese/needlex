    },
    {
      "type": "function",
      "function": {
        "name": "memory_search",
        "description": "Search Discovery Memory semantically before public bootstrap. Use this to inspect what local memory already knows.",
        "parameters": {
          "examples": [
            {
              "limit": 5,
              "query": "playwright installation"
            }
          ],
          "properties": {
            "config_path": {
              "type": "string"
            },
            "domain_hints": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "goal": {
              "description": "Alias for query.",
              "type": "string"
            },
            "limit": {
              "type": "integer"
            },
            "query": {
              "description": "Semantic retrieval query.",
              "type": "string"
            }
          },
          "type": "object"
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "memory_prune",
        "description": "Prune Discovery Memory to configured bounds.",
        "parameters": {
          "examples": [
            {}
          ],
          "properties": {
            "config_path": {
              "type": "string"
            }
          },
          "type": "object"
