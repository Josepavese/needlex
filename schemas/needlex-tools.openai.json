{
  "provider": "openai",
  "tools": [
    {
      "type": "function",
      "function": {
        "name": "web_crawl",
        "description": "Traverse linked pages starting from one seed URL.",
        "parameters": {
          "examples": [
            {
              "max_depth": 1,
              "max_pages": 5,
              "same_domain": true,
              "seed_url": "https://example.com/docs"
            }
          ],
          "properties": {
            "max_depth": {
              "type": "integer"
            },
            "max_pages": {
              "type": "integer"
            },
            "profile": {
              "type": "string"
            },
            "same_domain": {
              "type": "boolean"
            },
            "seed_url": {
              "type": "string"
            },
            "user_agent": {
              "type": "string"
            }
          },
          "required": [
            "seed_url"
          ],
          "type": "object"
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "web_query",
        "description": "Plan and execute a goal-oriented query with optional seed URL. Use discovery_mode=same_site_links to expand from the seed site, web_search for external bootstrap, or off only when seed_url is already the exact canonical page you want to read.",
        "parameters": {
          "examples": [
            {
              "discovery_mode": "same_site_links",
              "goal": "Find authentication flow details",
              "seed_url": "https://agentclientprotocol.com/protocol/overview"
            },
            {
              "discovery_mode": "web_search",
              "goal": "OpenAI API pricing"
            },
            {
              "discovery_mode": "off",
              "goal": "Read the verified initialize method page",
              "seed_url": "https://agentclientprotocol.com/protocol/initialization"
            }
          ],
          "properties": {
            "discovery_mode": {
              "description": "Discovery strategy. same_site_links = follow links from the seed site. web_search = bootstrap with search. off = do not expand beyond the seed URL and should be used only after the exact page has already been verified.",
              "enum": [
                "same_site_links",
                "web_search",
                "off"
              ],
              "type": "string"
            },
            "goal": {
              "description": "Retrieval objective or question to answer.",
              "type": "string"
            },
            "lane_max": {
              "type": "integer"
            },
            "profile": {
              "type": "string"
            },
            "seed_url": {
              "description": "Optional starting URL. If present, same_site_links expands from this site. When discovery_mode=off, this must be the exact canonical page and must already exist.",
              "type": "string"
            },
            "user_agent": {
              "type": "string"
            }
          },
          "required": [
            "goal"
          ],
          "type": "object"
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "web_read",
        "description": "Read one URL and return compact proof-carrying context first, plus diagnostic fields for deeper inspection.",
        "parameters": {
          "examples": [
            {
              "objective": "Extract pricing and policy details",
              "url": "https://example.com"
            }
          ],
          "properties": {
            "lane_max": {
              "type": "integer"
            },
            "objective": {
              "type": "string"
            },
            "profile": {
              "type": "string"
            },
            "url": {
              "type": "string"
            },
            "user_agent": {
              "type": "string"
            }
          },
          "required": [
            "url"
          ],
          "type": "object"
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "web_replay",
        "description": "Replay a stored trace and report deterministic stage completion.",
        "parameters": {
          "examples": [
            {
              "trace_id": "trace_123"
            }
          ],
          "properties": {
            "trace_id": {
              "type": "string"
            }
          },
          "required": [
            "trace_id"
          ],
          "type": "object"
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "web_diff",
        "description": "Compare two stored traces and report changed stages.",
        "parameters": {
          "examples": [
            {
              "trace_a": "trace_a",
              "trace_b": "trace_b"
            }
          ],
          "properties": {
            "trace_a": {
              "type": "string"
            },
            "trace_b": {
              "type": "string"
            }
          },
          "required": [
            "trace_a",
            "trace_b"
          ],
          "type": "object"
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "web_proof",
        "description": "Load proof records by trace id, proof id, or chunk id.",
        "parameters": {
          "examples": [
            {
              "chunk_id": "chk_123"
            },
            {
              "trace_id": "trace_123"
            }
          ],
          "properties": {
            "chunk_id": {
              "type": "string"
            },
            "proof_id": {
              "type": "string"
            },
            "trace_id": {
              "type": "string"
            }
          },
          "type": "object"
        }
      }
    },
    {
      "type": "function",
      "function": {
        "name": "web_prune",
        "description": "Prune local traces, proofs, fingerprints, and genome files.",
        "parameters": {
          "examples": [
            {
              "older_than_hours": 24
            }
          ],
          "properties": {
            "all": {
              "type": "boolean"
            },
            "older_than_hours": {
              "type": "integer"
            }
          },
          "type": "object"
        }
      }
    },
    {
      "type": "function",
