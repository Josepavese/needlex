{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://josepavese.github.io/needlex/schemas/proof.schema.json",
  "title": "NeedleXProof",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "chunk_id",
    "source_span",
    "transform_chain",
    "lane"
  ],
  "properties": {
    "chunk_id": {
      "type": "string",
      "minLength": 1
    },
    "source_span": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "selector",
        "char_start",
        "char_end"
      ],
      "properties": {
        "selector": {
          "type": "string",
          "minLength": 1
        },
        "char_start": {
          "type": "integer",
          "minimum": 0
        },
        "char_end": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "transform_chain": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "lane": {
      "type": "integer",
      "minimum": 0,
      "maximum": 4
    },
    "model_invocations": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "model",
          "purpose",
          "tokens_in",
          "tokens_out",
          "latency_ms"
        ],
        "properties": {
          "model": {
            "type": "string",
            "minLength": 1
          },
          "purpose": {
            "type": "string",
            "minLength": 1
          },
          "tokens_in": {
            "type": "integer",
            "minimum": 0
          },
          "tokens_out": {
            "type": "integer",
            "minimum": 0
          },
          "latency_ms": {
            "type": "integer",
            "minimum": 0
          }
        }
      }
    },
    "risk_flags": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
