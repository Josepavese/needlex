{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://josepavese.github.io/needlex/schemas/slm-task.schema.json",
  "title": "NeedleXSLMTask",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task",
    "model_class",
    "max_input_tokens",
    "max_output_tokens",
    "timeout_ms",
    "schema_name",
    "input"
  ],
  "properties": {
    "task": {
      "type": "string",
      "enum": [
        "resolve_ambiguity",
        "interpret_embedded_state",
        "diagnose_drift",
        "repair_evidence_graph",
        "guard_compression"
      ]
    },
    "model_class": {
      "type": "string",
      "enum": [
        "micro_solver",
        "structured_solver",
        "specialist_reader"
      ]
    },
    "max_input_tokens": {
      "type": "integer",
      "minimum": 1
    },
    "max_output_tokens": {
      "type": "integer",
      "minimum": 1
    },
    "timeout_ms": {
      "type": "integer",
      "minimum": 1
    },
    "schema_name": {
      "type": "string",
      "minLength": 1
    },
    "input": {
      "type": "object",
      "minProperties": 1
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "run_id": {
          "type": "string"
        },
        "trace_id": {
          "type": "string"
        },
        "chunk_id": {
          "type": "string"
        },
        "fingerprint": {
          "type": "string"
        },
        "failure_class": {
          "type": "string"
        },
        "reason_code": {
          "type": "string"
        }
      }
    }
  }
}
