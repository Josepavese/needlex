{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://josepavese.github.io/needlex/schemas/resultpack.schema.json",
  "title": "NeedleXResultPack",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "chunks",
    "sources",
    "cost_report"
  ],
  "properties": {
    "query": {
      "type": "string"
    },
    "objective": {
      "type": "string"
    },
    "chunks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "doc_id",
          "text",
          "score",
          "fingerprint",
          "confidence"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "doc_id": {
            "type": "string",
            "minLength": 1
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "heading_path": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "score": {
            "type": "number"
          },
          "fingerprint": {
            "type": "string",
            "minLength": 1
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "document_id",
          "url"
        ],
        "properties": {
          "document_id": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string"
          },
          "chunk_ids": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "proof_refs": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "cost_report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "latency_ms",
        "token_in",
        "token_out",
        "lane_path"
      ],
      "properties": {
        "latency_ms": {
          "type": "integer",
          "minimum": 0
        },
        "token_in": {
          "type": "integer",
          "minimum": 0
        },
        "token_out": {
          "type": "integer",
          "minimum": 0
        },
        "lane_path": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "integer",
            "minimum": 0,
            "maximum": 4
          }
        }
      }
    }
  },
  "anyOf": [
    {
      "required": [
        "query"
      ]
    },
    {
      "required": [
        "objective"
      ]
    }
  ]
}
