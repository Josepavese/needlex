{
  "version": "hard-case-corpus-v2",
  "acceptance": {
    "min_pass_rate": 1.0,
    "min_lane_lift_rate": 0.5,
    "min_objective_lift_avg": 0.05,
    "max_medium_or_high_risk_rate": 0.2,
    "required_families": [
      "embedded",
      "forum",
      "tiny",
      "compaction"
    ],
    "require_higher_lane_for": [
      "embedded",
      "forum",
      "tiny",
      "compaction"
    ],
    "allow_unclassified": false,
    "failure_class_map": [
      {
        "id": "FC01_PASS_RATE",
        "description": "overall hard-case pass-rate dropped below acceptance",
        "integration_gate": "block_slm_rollout",
        "match_any": [
          "pass_rate"
        ]
      },
      {
        "id": "FC02_LANE_LIFT",
        "description": "higher lanes are not producing measurable uplift",
        "integration_gate": "block_slm_rollout",
        "match_any": [
          "lane_lift_rate",
          "higher lane activation"
        ]
      },
      {
        "id": "FC03_OBJECTIVE_REGRESSION",
        "description": "objective focus improvement is below required average",
        "integration_gate": "block_slm_rollout",
        "match_any": [
          "objective_lift_avg"
        ]
      },
      {
        "id": "FC04_LOSSINESS_RISK",
        "description": "medium/high lossiness risk exceeds tolerance",
        "integration_gate": "block_slm_rollout",
        "match_any": [
          "medium_or_high_risk_rate"
        ]
      },
      {
        "id": "FC05_COVERAGE_GAP",
        "description": "required benchmark family coverage is missing",
        "integration_gate": "block_slm_rollout",
        "match_any": [
          "required family missing"
        ]
      }
    ]
  },
  "cases": [
    {
      "name": "embedded_lane3_vs_lane0",
      "objective": "company profile",
      "objective_terms": [
        "runtime",
        "agents",
        "proof",
        "context"
