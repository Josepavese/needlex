# Needle-X governance baseline.
# Hard limits block regressions.
# Target limits are pressure-only and should ratchet down over time.

HARD_MAX_PROD_LOC=26000
TARGET_MAX_PROD_LOC=23500

HARD_MAX_INTERNAL_PACKAGES=14
TARGET_MAX_INTERNAL_PACKAGES=11

HARD_MAX_RUNTIME_DEPS=4
TARGET_MAX_RUNTIME_DEPS=2

HARD_MAX_FILE_LOC=1800
TARGET_MAX_FILE_LOC=1400

HARD_MAX_AVG_FILE_LOC=235
TARGET_MAX_AVG_FILE_LOC=210

HARD_MAX_FILES_OVER_300=30
TARGET_MAX_FILES_OVER_300=22

HARD_MAX_FILES_OVER_350=22
TARGET_MAX_FILES_OVER_350=16

HARD_MAX_PACKAGE_LOC=6200
TARGET_MAX_PACKAGE_LOC=5000

HARD_MAX_STRUCTURE_ISSUES=0
TARGET_MAX_STRUCTURE_ISSUES=0

REQUIRE_GOFUMPT=1
REQUIRE_GOVET=1
REQUIRE_STATICCHECK=1
REQUIRE_STRUCTURE_LINT=1
REQUIRE_ADVISORY_LINT=1
REQUIRE_BENCHMARK_ADVISORY_LINT=1
